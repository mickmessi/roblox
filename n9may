local function gs_rainbow(x, y, w, h)
    -- draw a rainbow gradient line by splitting into segments
    local steps = math.max(1, math.floor(w));
    for i = 0, steps - 1 do
        local t   = i / steps;
        local hue = t * 360;
        -- HSV to RGB (S=1, V=1)
        local s, v = 1, 1;
        local hi   = math.floor(hue / 60) % 6;
        local f    = hue / 60 - math.floor(hue / 60);
        local p, q, tt = 0, v * (1 - f), v * f;
        local r, g, b;
        if     hi == 0 then r,g,b = v, tt, p
        elseif hi == 1 then r,g,b = q,  v, p
        elseif hi == 2 then r,g,b = p,  v, tt
        elseif hi == 3 then r,g,b = p,  q, v
        elseif hi == 4 then r,g,b = tt, p, v
        else                r,g,b = v,  p, q end;
        render.rect(
            vector(x + i,     y),
            vector(x + i + 1, y + h),
            color(math.floor(r*255), math.floor(g*255), math.floor(b*255), 255),
            0
        );
    end;
end;

-- Rainbow top line helper for GameSense style
local function gs_rainbow(x, y, w, h, alpha)
    alpha = alpha or 220;
    local steps = math.max(1, math.floor(w));
    local t = globals.realtime * 0.3; -- scroll speed
    for i = 0, steps - 1 do
        local hue = ((i / steps) + t) % 1.0;
        local h6  = hue * 6;
        local f   = h6 - math.floor(h6);
        local q   = 1 - f;
        local r, g, b;
        local s = math.floor(h6) % 6;
        if     s == 0 then r,g,b = 1, f, 0
        elseif s == 1 then r,g,b = q, 1, 0
        elseif s == 2 then r,g,b = 0, 1, f
        elseif s == 3 then r,g,b = 0, q, 1
        elseif s == 4 then r,g,b = f, 0, 1
        else               r,g,b = 1, 0, q end;
        render.rect(
            vector(x + i, y),
            vector(x + i + 1, y + h),
            color(math.floor(r*255), math.floor(g*255), math.floor(b*255), alpha),
            0
        );
    end;
end;

