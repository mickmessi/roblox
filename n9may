                    local icon_x   = list_x + pad_x;
                    local icon_y   = row_y + (row_h - iw.y) / 2;
                    local text_x   = icon_x + iw_ref.x + icon_gap;
                    local tw       = render.measure_text(1, nil, text_str);
                    local text_y   = row_y + (row_h - tw.y) / 2;
                    render.text(1, vector(icon_x, icon_y), e.accent:alpha_modulate(a), "d", icon_str);
                    render.text(1, vector(text_x, text_y), color(255, 255, 255, a),    "d", text_str);
                end;
            end;
        end;
    end);
end;

-- ═══════════════════════════════════════════════════════════════
--  SMART PEEK  (ported from Frost)
-- ═══════════════════════════════════════════════════════════════
do
    local ref = v14.misc.aimbot.smart_peek;

    -- NL ui.find references (map to may's existing v9 pattern)
    local rg_peek_assist   = v9.rage.main.peek_assist;   -- [1]=sw [2]=style [3]=autostop [4]=retreat
    local rg_double_tap    = v9.rage.main.double_tap;    -- switch
    local rg_min_damage    = v9.rage.selection.minimum_damage;

    local FL_ONGROUND = bit.lshift(1, 0);

    -- hitgroup constants
    local HG_GENERIC  = 0; local HG_HEAD    = 1; local HG_CHEST   = 2;
    local HG_STOMACH  = 3; local HG_LLEG    = 6; local HG_RLEG    = 7;
    local HG_LARM     = 4; local HG_RARM    = 5;

    -- hitbox constants
    local HB_HEAD=0; local HB_CHEST=5; local HB_STOMACH=3;
    local HB_LTHIGH=8;  local HB_RTHIGH=7;
    local HB_LCALF=10;  local HB_RCALF=9;
    local HB_LUARM=17;  local HB_RUARM=15;

    local to_hitgroups = {
        [HB_HEAD]=HG_HEAD, [HB_CHEST]=HG_CHEST, [HB_STOMACH]=HG_STOMACH,
        [HB_LTHIGH]=HG_LLEG, [HB_RTHIGH]=HG_RLEG, [HB_LCALF]=HG_LLEG, [HB_RCALF]=HG_RLEG,
        [HB_LUARM]=HG_LARM, [HB_RUARM]=HG_RARM,
    };

    -- per-weapon ragebot layout
    local rg_layouts = {};
    local function get_layout(wname)
        local l = {};
        l.selection = {
            head_scale = ui.find("Aimbot","Ragebot","Selection",wname,"Multipoint","Head Scale"),
            body_scale = ui.find("Aimbot","Ragebot","Selection",wname,"Multipoint","Body Scale"),
            min_damage = ui.find("Aimbot","Ragebot","Selection",wname,"Min. Damage"),
            hit_chance = ui.find("Aimbot","Ragebot","Selection",wname,"Hit Chance"),
        };
        l.safety = {
            body_aim              = ui.find("Aimbot","Ragebot","Safety",wname,"Body Aim"),
            safe_points           = ui.find("Aimbot","Ragebot","Safety",wname,"Safe Points"),
            ensure_hitbox_safety  = ui.find("Aimbot","Ragebot","Safety",wname,"Ensure Hitbox Safety"),
        };
        return l;
    end;
    rg_layouts["SSG-08"]  = get_layout("SSG-08");
    rg_layouts["Deagle"]  = get_layout("Desert Eagle");
    rg_layouts["Pistols"] = get_layout("Pistols");

    -- debug_overlay box_new (needed for peek position visualisation)
    local _Vector = ffi.typeof("struct { float x, y, z; }");
    local _Color  = ffi.typeof("struct { uint8_t r, g, b, a; }");
    local _box_new_fn = utils.get_vfunc(
        "engine.dll", "VDebugOverlay004", 21,
        "void(__thiscall*)(void*,const $&,const $&,const $&,const $&,$*,$*,float)",
        _Vector, _Vector, _Vector, _Vector, _Color, _Color
    );
    local function box_new(origin, mins, maxs, angles, face, edge, dur)
        _box_new_fn(
            _Vector(origin:unpack()), _Vector(mins:unpack()),
            _Vector(maxs:unpack()),   _Vector(angles:unpack()),
            _Color(face:unpack()),    _Color(edge:unpack()), dur
        );
    end;

    local sp_data      = nil;
    local sp_rate_time = 0;
    local sp_retreat_pos = nil;

    local function sp_clear()
        sp_data = nil; sp_rate_time = 0; sp_retreat_pos = nil;
    end;

    local function sp_reset_overrides()
        rg_peek_assist[4]:override();
        rg_double_tap:override();
        for _, v in pairs(rg_layouts) do
            v.selection.head_scale:override();
            v.selection.body_scale:override();
            v.selection.hit_chance:override();
            v.safety.body_aim:override();
            v.safety.safe_points:override();
            v.safety.ensure_hitbox_safety:override();
        end;
    end;

    local function sp_prepare_overrides()
        local hc = ref.hit_chance:get();
        local unsafe = ref.unsafety:get();
        rg_peek_assist[4]:override("On Shot");
        for _, v in pairs(rg_layouts) do
            v.selection.head_scale:override(100);
            v.selection.body_scale:override(100);
            if hc ~= 0 then v.selection.hit_chance:override(hc); end;
            if unsafe then
                v.safety.body_aim:override("Default");
                v.safety.safe_points:override("Default");
                v.safety.ensure_hitbox_safety:override({});
            end;
        end;
    end;

    local function sp_hg(hitbox)
        return to_hitgroups[hitbox] or HG_GENERIC;
    end;

    local function sp_dmg_mult(hg)
        if hg == HG_HEAD then return 4.0; end;
        if hg == HG_STOMACH then return 1.25; end;
        if hg == HG_LLEG or hg == HG_RLEG then return 0.75; end;
        return 1.0;
    end;

    local function sp_scale_dmg(enemy, dmg, hg, armor_ratio)
        dmg = dmg * sp_dmg_mult(hg);
        if enemy.m_ArmorValue > 0 then
            if hg == HG_HEAD then
                if enemy.m_bHasHelmet then dmg = dmg * (armor_ratio * 0.5); end;
            else
                dmg = dmg * (armor_ratio * 0.5);
            end;
        end;
        return dmg;
    end;

    local function sp_sim_dmg(start_pos, end_pos, enemy, hg, winfo)
        local delta = end_pos - start_pos;
        local dmg = winfo.damage;
        local length = math.min(winfo.range, delta:length());
        dmg = dmg * math.pow(winfo.range_modifier, length * 0.002);
        return sp_scale_dmg(enemy, dmg, hg, winfo.armor_ratio);
    end;

    local function sp_get_hitbox_list()
        local list = {};
        if ref.hitboxes:get("Head")    then table.insert(list, HB_HEAD);   end;
        if ref.hitboxes:get("Chest")   then table.insert(list, HB_CHEST);  end;
        if ref.hitboxes:get("Stomach") then table.insert(list, HB_STOMACH);end;
        if ref.hitboxes:get("Arms") then
            table.insert(list, HB_LUARM); table.insert(list, HB_RUARM);
        end;
        if ref.hitboxes:get("Legs") then
            table.insert(list, HB_LTHIGH); table.insert(list, HB_RTHIGH);
            table.insert(list, HB_LCALF);  table.insert(list, HB_RCALF);
        end;
        return list;
    end;

    local function sp_wish_hitboxes(list, player, weapon, target, wish_dmg)
        local hitboxes = {};
        local eye = player:get_eye_position();
        local winfo = weapon:get_weapon_info();
        local health = target.m_iHealth;
        for i = 1, #list do
            local hb = list[i];
            local hg = sp_hg(hb);
            local pos = target:get_hitbox_position(hb);
            local dmg = sp_sim_dmg(eye, pos, target, hg, winfo);
            if dmg >= wish_dmg or dmg >= health then
                table.insert(hitboxes, { index=i, pos=pos });
            end;
        end;
        return hitboxes;
    end;

    local function sp_trace_dmg(player, target, eye, hitboxes, wish_dmg)
        local health = target.m_iHealth;
        for i = 1, #hitboxes do
            local dmg = utils.trace_bullet(player, eye, hitboxes[i].pos, function(e)
                return e ~= player and e:is_enemy();
            end);
            if dmg >= wish_dmg or dmg >= health then return true; end;
        end;
        return false;
    end;

    local function sp_weapon_type(weapon, winfo)
        local idx = weapon:get_weapon_index();
        if idx == 1  then return "Deagle";  end;
        if idx == 64 then return nil;        end;
        if idx == 40 then return "SSG-08";  end;
        if winfo.weapon_type == 1 then return "Pistols"; end;
        return nil;
    end;

    local function sp_update_movement(cmd, player, dest)
        local origin = player:get_origin();
        local delta  = dest - origin;
        if delta:length2dsqr() < 25 then
            local vel = player.m_vecVelocity;
            cmd.move_yaw = vel:angles().y;
            cmd.forwardmove = -vel:length();
            cmd.sidemove = 0;
            return true, delta:length2dsqr();
        end;
        local ang = delta:angles();
        cmd.move_yaw = ang.y;
        cmd.forwardmove = 450; cmd.sidemove = 0;
        return false, delta:length2dsqr();
    end;

    local function sp_block_keys(cmd)
        cmd.in_duck=false; cmd.in_jump=false; cmd.in_speed=false;
        cmd.in_forward=true; cmd.in_back=false; cmd.in_moveleft=false; cmd.in_moveright=false;
    end;

    local function sp_update_sim(cmd, player, target, ctx, angle, hitboxes, wish_dmg)
        cmd.view_angles.y = angle;
        ctx:think(1);
        if bit.band(ctx.flags, FL_ONGROUND) == 0 then return nil, false; end;
        local eye = ctx.origin + vector(0, 0, ctx.view_offset);
        local found = sp_trace_dmg(player, target, eye, hitboxes, wish_dmg);
        if found then ctx:think(1); end;
        return ctx, found;
    end;

    events.createmove(function(cmd)
        if not ref.switch:get() then sp_clear(); sp_reset_overrides(); return; end;

        local me = entity.get_local_player();
        if me == nil then return; end;
        local weapon = me:get_player_weapon(); if weapon == nil then return; end;
        local winfo  = weapon:get_weapon_info(); if winfo == nil then return; end;
        local wtype  = sp_weapon_type(weapon, winfo);

        if not ref.weapons:get(wtype) then sp_clear(); sp_reset_overrides(); return; end;

        -- check player ready
        local ready = winfo.max_clip1 ~= 0 and weapon.m_iClip1 ~= 0
            and globals.curtime >= me.m_flNextAttack
            and globals.curtime >= weapon.m_flNextPrimaryAttack;

        local dt = globals.frametime;
        local simtime  = ref.simulation:get() * 0.01;
        local rate_lim = ref.rate_limit:get()  * 0.01;
        local wish_dmg = rg_min_damage:get();
        local hb_list  = sp_get_hitbox_list();
        local range    = ref.dev_mode:get() and ref.range:get()   or 20;
        local retreat  = ref.dev_mode:get() and ref.retreat:get() or 25;

        -- update existing peek
        if sp_data ~= nil then
            local ok, _ = pcall(function() return sp_data.target[0]; end);
            if not ok then sp_clear(); sp_reset_overrides(); return; end;

            local target = sp_data.target;
            local wd2 = wish_dmg;
            if wd2 >= 100 then wd2 = wd2 + target.m_iHealth - 100; end;
            local hitboxes = sp_wish_hitboxes(hb_list, me, weapon, target, wd2);
            local eye = sp_data.ctx.origin + vector(0, 0, sp_data.ctx.view_offset);
            local found = sp_trace_dmg(me, target, eye, hitboxes, wd2);
            if found then sp_data.simtime = 0; end;
            sp_data.simtime = sp_data.simtime + dt;

            if sp_data.simtime <= simtime then
                if winfo.weapon_type == 5 and not me.m_bIsScoped then
                    -- wait for scope
                elseif sp_data.retreat <= 0 then
                    if sp_retreat_pos == nil then
                        local origin = me:get_origin();
                        local dir = sp_data.ctx.origin - origin; dir:normalize();
                        local pos = sp_data.ctx.origin - dir * retreat;
                        local tr = utils.trace_hull(origin, pos,
                            sp_data.ctx.obb_mins, sp_data.ctx.obb_maxs, me, 0x201400B, 0);
                        sp_retreat_pos = tr.end_pos;
                    end;
                    local is_qs, _ = sp_update_movement(cmd, me, sp_data.ctx.origin);
                    sp_block_keys(cmd); sp_prepare_overrides();
                    sp_data.retreat = 0;
                    if is_qs then sp_data.retreat = 1; end;
                    box_new(sp_data.ctx.origin, sp_data.ctx.obb_mins, sp_data.ctx.obb_maxs,
                        vector(), color(0,0,0,0), ref.color:get(), globals.tickinterval*2);
                    return;
                end;
            end;

            if not ready then sp_clear(); sp_reset_overrides(); return; end;
            if sp_data.ctx == nil or sp_data.retreat == -1 then return; end;

            sp_data.retreat = sp_data.retreat + 1;
            local is_qs, _ = sp_update_movement(cmd, me, sp_retreat_pos);
            sp_block_keys(cmd); sp_prepare_overrides();

            local vel = me.m_vecVelocity;
            local delta = sp_retreat_pos - me:get_origin();
            local ang_diff = delta:angles() - vel:angles();
            local spdsqr = vel:length2dsqr();

            if spdsqr > 1600 and math.abs(ang_diff.y) < 20 then
                rage.exploit:force_teleport();
                rg_double_tap:override(false);
            end;

            if ready and is_qs then sp_clear(); sp_reset_overrides(); end;
            return;
        end;

        -- try to start a new peek
        if not rg_peek_assist[1]:get() then return; end;
        if rate_lim > 0 then
            if sp_rate_time > 0 then sp_rate_time = sp_rate_time - dt; return; end;
            sp_rate_time = rate_lim;
        end;
        if cmd.in_forward or cmd.in_back or cmd.in_moveleft or cmd.in_moveright then return; end;
        if bit.band(me.m_fFlags, FL_ONGROUND) == 0 then return; end;
        if me.m_vecVelocity:length2dsqr() > 6400 then return; end;

        local threat = entity.get_threat();
        if threat == nil or threat:is_dormant() then return; end;

        local wd2 = wish_dmg;
        if wd2 >= 100 then wd2 = wd2 + threat.m_iHealth - 100; end;
        local hitboxes = sp_wish_hitboxes(hb_list, me, weapon, threat, wd2);
        if sp_trace_dmg(me, threat, me:get_eye_position(), hitboxes, wd2) then return; end;

        -- calculate left/right peek angles
        local delta = threat:get_origin() - me:get_origin();
        local base_yaw = delta:angles().y + 180;
        local left_angle  = base_yaw - 90;
        local right_angle = base_yaw + 90;

        -- backup cmd
        local old_yaw = cmd.view_angles.y;
        local old_fm  = cmd.forwardmove; local old_sm = cmd.sidemove;
        local old_duck = cmd.in_duck; local old_jump = cmd.in_jump; local old_spd = cmd.in_speed;
        cmd.forwardmove=450; cmd.sidemove=0; cmd.in_duck=false; cmd.in_jump=false; cmd.in_speed=false;

        local left_ctx  = me:simulate_movement(nil, vector(), 0x01);
        local right_ctx = me:simulate_movement(nil, vector(), 0x01);
        local left_step=0; local right_step=0;

        for i = 1, range do
            if left_step ~= -1 then
                left_step = i;
                local ctx, found = sp_update_sim(cmd, me, threat, left_ctx, left_angle, hitboxes, wd2);
                if ctx == nil then left_step = -1;
                elseif found then sp_data = { ctx=ctx, target=threat, simtime=0, retreat=-1, teleport=0 }; break; end;
            end;
            if right_step ~= -1 then
                right_step = i;
                local ctx, found = sp_update_sim(cmd, me, threat, right_ctx, right_angle, hitboxes, wd2);
                if ctx == nil then right_step = -1;
                elseif found then sp_data = { ctx=ctx, target=threat, simtime=0, retreat=-1, teleport=0 }; break; end;
            end;
        end;

        -- restore cmd
        cmd.view_angles.y=old_yaw; cmd.forwardmove=old_fm; cmd.sidemove=old_sm;
        cmd.in_duck=old_duck; cmd.in_jump=old_jump; cmd.in_speed=old_spd;
    end);

    events.aim_fire(function()
        if sp_data ~= nil then sp_clear(); end;
    end);

    events.game_event(function(ev)
        if ev.name == "round_start" or ev.name == "player_death" then
            local lp = entity.get_local_player();
            if ev.name == "player_death" then
                local idx = ev.userid;
                if lp == nil or (idx ~= nil and idx ~= lp:get_index()) then return; end;
            end;
            sp_clear();
            sp_reset_overrides();
        end;
    end);
end;

-- ═══════════════════════════════════════════════════════════════
--  CLANTAG  (ported from Frost)
-- ═══════════════════════════════════════════════════════════════
do
    local ref = v14.visuals.clantag;
    local ref_clan_tag = ui.find("Miscellaneous", "Main", "In-Game", "Clan Tag");

    local MAYBACH_LIST = {
        "✦", "✦ M", "✦ MA", "✦ MAY", "✦ MAYB", "✦ MAYBA", "✦ MAYBAC", "✦ MAYBACH",
        "✦ MAYBACH", "✦ MAYBACH", "✦ MAYBACH", "✦ MAYBACH",
        "✦ AYBACH", "✦ YBACH", "✦ BACH", "✦ ACH", "✦ CH", "✦ H",
        "✦ H", "✦ CH", "✦ ACH", "✦ BACH", "✦ YBACH", "✦ AYBACH",
        "✦ MAYBACH", "✦ MAYBACH", "✦ MAYBACH", "✦",
    };

    local function round(x) return math.floor(x + 0.5); end;

    local function generate_list(value)
        local list = { "" };
        for i = 1, #value do table.insert(list, value:sub(1, i)); end;
        for _ = 1, 5 do table.insert(list, value); end;
        for i = 1, #value do table.insert(list, value:sub(i, #value)); end;
        table.insert(list, "");
        return list;
    end;

    local ct_current_list = MAYBACH_LIST;
    local ct_prev_text    = nil;

    local function ct_get_time() return round(globals.curtime * 2.4); end;

    local function on_net_update_end()
        if not globals.is_in_game then return; end;
        local idx  = ct_get_time() % #ct_current_list + 1;
        local text = ct_current_list[idx] or "";
        if ct_prev_text ~= text then
            ct_prev_text = text;
            common.set_clan_tag(text);
        end;
    end;

    local function on_input_static(item)
        local v = item:get();
        ct_current_list = (v ~= "") and { v } or MAYBACH_LIST;
    end;

    local function on_input_animated(item)
        local v = item:get();
        ct_current_list = (v ~= "") and generate_list(v) or MAYBACH_LIST;
    end;

    local function on_style(item)
        if item:get() == "Static" then
            ref.input:unset_callback(on_input_animated);
            ref.input:set_callback(on_input_static, true);
        else
            ref.input:unset_callback(on_input_static);
            ref.input:set_callback(on_input_animated, true);
        end;
    end;

    local function on_mode(item)
        local v = item:get();
        if v == "MAYBACH" then
            ct_current_list = MAYBACH_LIST;
        end;
        if v == "Custom" then
            ref.style:set_callback(on_style, true);
        else
            ref.style:unset_callback(on_style);
            ref.input:unset_callback(on_input_static);
            ref.input:unset_callback(on_input_animated);
        end;
    end;

    ref.switch:set_callback(function(item)
        local v = item:get();
        if not v then common.set_clan_tag(""); end;
        if v then
            ref.mode:set_callback(on_mode, true);
        else
            ref.mode:unset_callback(on_mode);
            ref.style:unset_callback(on_style);
            ref.input:unset_callback(on_input_static);
            ref.input:unset_callback(on_input_animated);
        end;
        if ref_clan_tag ~= nil then ref_clan_tag:override(v and false or nil); end;
        events.net_update_end(on_net_update_end, v);
        events.level_init(function() ct_prev_text = nil; end, v);
    end, true);
end;

