    end;
    local function l_hl_mm(info)
        local dd = info.damage ~= info.wanted_damage;
        local dh = info.hitgroup ~= info.wanted_hitgroup;
        if not dd and not dh then return ""; end;
        local p = {};
        if dd then p[#p+1] = tostring(info.wanted_damage); end;
        if dh then p[#p+1] = l_hl_hitgroups[info.wanted_hitgroup] or "?"; end;
