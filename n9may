            end;
            if vel > RUN * WALK_MOD and state == RUN_TO_WALK then
                state = WALK_TO_RUN; wtr = math.max(0.01, wtr);
            elseif vel < RUN * WALK_MOD and state == WALK_TO_RUN then
                state = RUN_TO_WALK; wtr = math.min(0.99, wtr);
            end;
            return wtr, state;
        end;

        R.predictedFootYaw = function(self, foot_last, eye_yaw, lby, wtr, vel, min_by, max_by)
            local vlen = math.min(vel:length(), 260.0);
            local foot = math.clamp(foot_last, is_gpt and -180 or -360, is_gpt and 180 or 360);
            local delta = angle_diff(eye_yaw, foot);
            if delta > max_by then foot = eye_yaw - (is_gpt and max_by or math.abs(max_by));
            elseif delta < min_by then foot = eye_yaw + (is_gpt and min_by or math.abs(min_by)) end;
            foot = angle_normalize(foot);
            local ti = globals.tickinterval;
            if vlen > 0.1 or vel.z > 100 then
                foot = approach_angle(eye_yaw, foot, ti * (is_gpt and (40+30*wtr) or (30+20*wtr)));
            else
                foot = approach_angle(lby, foot, ti * 100);
            end;
            return foot;
        end;

        R.main = function(self, idx)
            if not idx or idx <= 0 then return end;
            if not blyat.get_address(idx) then return end;
            local as = blyat.get_animstate(idx); if not as then return end;
            self:updateLayers(idx);
            if not self.cache[idx] then self.cache[idx] = {} end;
            local vel   = blyat.get_velocity(idx);
            local vlen  = vel:length();
            local maxd  = self:getMaxDesyncDelta(idx);
            local desync= maxd * 58;
            local eye   = as.flEyeYaw;
            local gfy   = as.flGoalFeetYaw;
            local lby   = entity.get(idx).m_flLowerBodyYawTarget;
            local adiff = angle_diff(eye, gfy);
            local side  = adiff < 0 and 1 or (adiff > 0 and -1 or 0);
            local absd  = math.abs(adiff);
            local absc  = math.abs(self.cache[idx].m_flAbsAngleDiff or absd);
            local try   = true;
            if absd > 0 or absc > 0 then
                if absd < absc then
                    try = false;
                    if vlen > (self.cache[idx].m_flVelocityLengthXY or 0) then try = true end;
                end;
                if self:isLBYFlexing(idx) then try = true end;
                if try then
                    local cur = math.max(absd, absc);
                    if absd <= 10 and absc <= 10 then desync = cur;
                    elseif absd <= 35 and absc <= 35 then desync = math.max(29, cur);
                    else desync = math.clamp(cur, 29, 57) end;
                end;
            end;
            desync = math.clamp(desync, 0, maxd * 58);
            self:updateSafety(idx, side, desync);
            if vlen > 5 and side ~= 0 then
                local sp = self.safepoints[idx];
                if sp and sp[1] and sp[2] and sp[3]
                and sp[1].m_playback_rate and sp[2].m_playback_rate and sp[3].m_playback_rate then
                    if self.layers[idx] and self.layers[idx][6] then
                        local srv = self.layers[idx][6].m_playback_rate;
                        local d1  = math.abs(srv - sp[1].m_playback_rate);
                        local d2  = math.abs(srv - sp[2].m_playback_rate);
                        local d3  = math.abs(srv - sp[3].m_playback_rate);
                        local best_d = math.min(d1, d2, d3);
                        if best_d == d1 then desync = sp[1].m_flDesync;
                        elseif best_d == d2 then desync = sp[2].m_flDesync;
                        else desync = sp[3].m_flDesync end;
                    end;
                end;
            end;
            self.cache[idx].m_flAbsAngleDiff      = absd;
            self.cache[idx].m_flVelocityLengthXY  = vlen;
            self.cache[idx].m_flDesync             = desync * side;
            self.cache[idx].m_flGoalFeetYaw        = gfy;
            self.cache[idx].m_flWalkToRunTransition, self.cache[idx].m_bWalkToRunTransitionState = self:transition(
                self.cache[idx].m_flWalkToRunTransition or 0,
                self.cache[idx].m_bWalkToRunTransitionState or false,
                globals.tickinterval, vlen
            );
            self.cache[idx].m_flPredictedFootYaw = self:predictedFootYaw(
                gfy, eye + self.cache[idx].m_flDesync, lby,
                self.cache[idx].m_flWalkToRunTransition, vel, -57, 57
            );
            as.flGoalFeetYaw = self.cache[idx].m_flPredictedFootYaw;
        end;

        R.checkResolvingStage = function(self, idx)
            if not idx or idx <= 0 then return "Invalid player index" end;
            if not blyat.get_animstate(idx)  then return "Resolving: 1/4" end;
            if not self.cache[idx]           then return "Resolving: 2/4" end;
            if not self.layers[idx]          then return "Resolving: 3/4" end;
            if not self.safepoints[idx]      then return "Resolving: 4/4" end;
            return "Resolved";
        end;

        R.debug = function(self, idx)
            cvar.clear:call();
            if not idx or idx <= 0 then print_raw("Resolver: invalid index"); return end;
            local as = blyat.get_animstate(idx);
            if not as then print_raw("Resolver: no animstate for " .. idx); return end;
            local c = self.cache[idx] or {};
            print_raw(string.format("[Resolver Debug %s] Player idx %d", is_gpt and "GPT" or "Default", idx));
            print_raw(string.format("  eye=%.2f  gfy=%.2f  desync=%.2f  pred_fy=%.2f",
                as.flEyeYaw, as.flGoalFeetYaw, c.m_flDesync or 0, c.m_flPredictedFootYaw or 0));
            print_raw(string.format("  vel_xy=%.2f  abs_diff=%.2f  lby_flex=%s",
                c.m_flVelocityLengthXY or 0, c.m_flAbsAngleDiff or 0, tostring(self:isLBYFlexing(idx))));
        end;

        return R;
    end;

    local resolver_default = make_resolver(false);
    local resolver_gpt     = make_resolver(true);

    local function get_resolver()
        return reso_ver:get() == "GPT" and resolver_gpt or resolver_default;
    end;

    -- main update: post_update_clientside_animation
    local reso_player_names = {};
    events.post_update_clientside_animation(function()
        if not reso_en:get() then return end;
        local lp = entity.get_local_player();
        if not lp or not lp:is_alive() then return end;
        local R = get_resolver();
        entity.get_players(true, false, function(ent)
            if not ent:is_enemy() or not ent:is_alive() or ent:is_dormant() then return end;
            local idx = ent:get_index(); if not idx then return end;
            if lp:get_index() == idx then return end;
            local name = ent:get_name();
            if name then reso_player_names[name] = true end;
            R:main(idx);
        end);
        -- cleanup disconnected players
        for name in pairs(reso_player_names) do
            local found = false;
            entity.get_players(true, false, function(e) if e:get_name() == name then found = true end end);
            if not found then reso_player_names[name] = nil end;
        end;
    end);

    -- version visibility
    events.render(function()
        reso_ver:visibility(reso_en:get());
    end);

    -- ESP: resolver state tag on enemy
    esp.enemy:new_text("Resolver State", "Resolved", function(ent)
        if not reso_en:get() then return end;
        if not ent:is_enemy() or not ent:is_alive() or ent:is_dormant() then return end;
        return get_resolver():checkResolvingStage(ent:get_index());
    end);
end;

do
